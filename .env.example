# PostgreSQL 连接串（本地 Docker 或 Neon / Vercel Postgres）
# 本地示例: postgres://postgres:postgres@localhost:5432/rice_picture
# Neon 示例: postgres://user:pass@ep-xxx.aws.neon.tech/neondb?sslmode=require
POSTGRES_URL=

# 会话 JWT 签名密钥（随便生成一段长随机字符串）
# 生成: openssl rand -base64 32
SESSION_SECRET=

# 阿里百炼 DashScope API Key（服务端使用，切勿暴露到前端）
DASHSCOPE_API_KEY=
